  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b797a13282c6bb443b6807b81df5efa6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  artifactId: luzia
  title: Luzia
  shortDescription: "O f\xF3ssil humano mais antigo das Am\xE9ricas, com cerca de
    11.500 anos."
  longDescription: "Luzia \xE9 o nome dado ao cr\xE2nio f\xF3ssil de uma mulher que
    viveu h\xE1 aproximadamente 11.500 anos, descoberto em 1975 na regi\xE3o de Lagoa
    Santa, Minas Gerais. Considerado por d\xE9cadas o esqueleto humano mais antigo
    das Am\xE9ricas, Luzia se tornou um s\xEDmbolo da pr\xE9-hist\xF3ria brasileira
    e um marco para a paleoantropologia mundial. Suas caracter\xEDsticas morfol\xF3gicas
    reacenderam debates sobre as rotas de povoamento do continente americano. Em
    setembro de 2018, o inc\xEAndio que devastou o Museu Nacional do Rio de Janeiro
    consumiu grande parte do laborat\xF3rio onde Luzia era guardada. Pesquisadores
    conseguiram recuperar fragmentos do cr\xE2nio em meio aos escombros, num esfor\xE7o
    heroico de preserva\xE7\xE3o. Luzia n\xE3o \xE9 apenas um f\xF3ssil \u2014 \xE9
    a mem\xF3ria mais antiga das Am\xE9ricas, e sua perda parcial representa uma
    ferida coletiva na hist\xF3ria da ci\xEAncia brasileira."
  narration: {fileID: 8300000, guid: 9c412a0f8f2ff014f845398510926f16, type: 3}
  thumbnail: {fileID: 0}
